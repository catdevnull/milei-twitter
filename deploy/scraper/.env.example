API_TOKEN=
API_URL=https://milei.nulo.lol

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Browser scraper auth/proxy. Prefer ACCOUNTS_LIST in production so the
# container does not depend on an extra mounted secrets file.
ACCOUNTS_LIST=
ACCOUNTS_FILE_FORMAT=username:password:email:emailPassword:authToken:ANY
PROXY_URL=
WEBSHARE_PROXY_LIST_URL=
TWITTER_BROWSER_HEADLESS=0

# SocialData fallback.
SOCIALDATA_API_KEY=
SOCIALDATA_SELFHOSTED_URL=
