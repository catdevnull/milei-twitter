API_TOKEN=1234
API_URL=https://milei.nulo.lol

ACCOUNTS_FILE_FORMAT="username:password:email:emailPassword:twoFactorSecret:ANY:authToken"

ACCOUNTS_LIST="juanpe:12345678:juanpe@gmail.com:12345678:12345678:ANY:12345678"
# or 
ACCOUNTS_FILE_PATH=accounts.txt
# or
SOCIALDATA_API_KEY="ID|TOKEN"

# Browser-backed Twitter scraper. Keep real values in your local env only.
# PROXY_URL can be either http://user:pass@host:port, user:pass@host:port,
# host:port:user:pass, or host:port. If unset, WEBSHARE_PROXY_LIST_URL is used.
PROXY_URL="http://username:password@host:port"
WEBSHARE_PROXY_LIST_URL="https://proxy.webshare.io/api/v2/proxy/list/download/..."
TWITTER_BROWSER_USER_DATA_DIR=".twitter-browser-profile"
# Leave unset in Docker to use Playwright's bundled Chromium. Set to "chrome"
# locally if you want to use a system Chrome install.
TWITTER_BROWSER_CHANNEL="chrome"
TWITTER_BROWSER_HEADLESS="0"
# Refuses direct Twitter traffic by default.
TWITTER_ALLOW_DIRECT="0"
REBROWSER_PATCHES_RUNTIME_FIX_MODE="alwaysIsolated"
REBROWSER_PATCHES_SOURCE_URL="app.js"
REBROWSER_PATCHES_UTILITY_WORLD_NAME="util"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
